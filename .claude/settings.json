{
  "permissions": {
    "allow": [
      "Edit(*)",
      "Write(*)",
      "NotebookEdit(*)",
      "Bash(pnpm *)",
      "Bash(pnpm run *)",
      "Bash(npx *)",
      "Bash(pnpx *)",
      "Bash(node *)",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(echo *)",
      "Bash(which *)",
      "Bash(open *)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:getdesign.md)",
      "WebFetch(domain:registry.npmjs.org)",
      "WebSearch"
    ],
    "deny": [],
    "ask": [
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(pnpm add *)",
      "Bash(pnpm remove *)",
      "Bash(docker *)",
      "Bash(kill *)",
      "Bash(killall *)"
    ]
  },
  "plansDirectory": "./docs/plans",
  "outputStyle": "Explanatory",
  "respectGitignore": true,
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "npx prettier --write $CLAUDE_FILE_PATH 2>/dev/null || true",
            "timeout": 5000,
            "async": true,
            "statusMessage": "Formatting..."
          }
        ]
      }
    ]
  }
}
